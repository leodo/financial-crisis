FC_API_BIND=127.0.0.1:18080
RUST_LOG=info,fc_api=debug

# Optional. The MVP runtime uses in-memory demo data, but migrations and
# deployment files are prepared for PostgreSQL/TimescaleDB.
DATABASE_URL=postgres://financial:financial@localhost:5432/financial_crisis

# demo: in-memory seed data; postgres: read indicators and observations from DATABASE_URL.
FC_DATA_MODE=demo

# Optional source credentials.
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
