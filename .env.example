FC_API_BIND=127.0.0.1:18080
RUST_LOG=info,fc_api=debug

# Optional. The default runtime uses in-memory demo data. SQLite supports
# local historical data; PostgreSQL/TimescaleDB remains the production path.
DATABASE_URL=postgres://financial:financial@localhost:5432/financial_crisis
FC_SQLITE_PATH=data/fc-local.sqlite
FC_RAW_DATA_DIR=data/raw

# demo: in-memory seed data; sqlite: read local SQLite; postgres: read DATABASE_URL.
FC_DATA_MODE=demo

# Optional source credentials. Default FRED backfill uses public graph CSV and does
# not require FRED_API_KEY; set it only for `backfill fred --api`.
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
